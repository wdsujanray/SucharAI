{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document containing authentication and presentation data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["id", "email", "fullName", "avatarUrl", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation thread created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "isArchived": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual chat message within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "conversationId", "role", "content", "createdAt"]
    },
    "DocumentRecord": {
      "title": "DocumentRecord",
      "description": "A file uploaded to a conversation to ground search contexts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "filename": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "conversationId", "filename", "mimeType", "size", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user accounts mapped by their Firebase Auth Uid."
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Core conversation threads."
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Stateless chat messages connected to threads."
    },
    "documents/{documentId}": {
      "schema": "DocumentRecord",
      "description": "Document knowledge items uploaded to threads."
    }
  }
}
